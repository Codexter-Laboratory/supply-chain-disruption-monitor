# PostgreSQL (local or Docker Compose service `postgres`)
DATABASE_URL="postgresql://scm:scm@localhost:5432/supply_chain_monitor?schema=public"

PORT=3000

# Set to "true" to enable the scheduled simulation tick (orchestrator scaffold)
SIMULATION_ENABLED=false

