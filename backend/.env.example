# PostgreSQL (local or Docker Compose service `postgres`)
DATABASE_URL="postgresql://scm:scm@localhost:5432/supply_chain_monitor?schema=public"

PORT=3000

# Enables the periodic orchestrator tick (events + pricing ingestion + news + KPI scheduler).
# Independent of *_MODE vars: orchestrator ticks are not the same thing as domain source modes.
SIMULATION_ENABLED=false

# Domain source modes (simulation | real | hybrid): intended data path per area. No new providers
# run purely from env—only implementations that already exist honour these (see docs/source-modes.md).
# PRICING_MODE=simulation
# NEWS_MODE=simulation
# VESSEL_TRACKING_MODE=simulation
# ROUTES_MODE=simulation
# EVENTS_MODE=simulation

# When PRICING_MODE=real — base URL and API key for the commodity pricing adapter (OIL/BRENT wired today).
# PRICING_API_BASE_URL="https://example.com"
# PRICING_API_KEY=""

# Optional RSS feed URL for news ingestion (otherwise mock headlines are used)
# NEWS_RSS_URL="https://example.com/feed.xml"
