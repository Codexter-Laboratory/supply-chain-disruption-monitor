# PostgreSQL (local or Docker Compose service `postgres`)
DATABASE_URL="postgresql://scm:scm@localhost:5432/supply_chain_monitor?schema=public"

PORT=3000

# Enables the periodic orchestrator tick (events + pricing ingestion + news + KPI scheduler).
# Independent from PRICING_MODE: simulation tick can run with real or simulated quote providers.
SIMULATION_ENABLED=false

# Energy quote ingestion: "simulation" (default, synthetic quotes) or "real" (HTTP-backed baselines).
# PRICING_MODE=simulation

# When PRICING_MODE=real — base URL and API key for the commodity pricing adapter.
# PRICING_API_BASE_URL="https://example.com"
# PRICING_API_KEY=""

# Optional RSS feed URL for news ingestion (otherwise mock headlines are used)
# NEWS_RSS_URL="https://example.com/feed.xml"
