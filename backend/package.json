    "graphql-subscriptions": "^2.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
